{
  "version": "1.0",
  "ai": {
    "provider": "gemini",
    "model": "gemini-2.0-flash",
    "api_key_env": "GOOGLE_API_KEY",
    "temperature": 0.3,
    "max_tokens": 8192,
    "languages": ["en", "zh"],
    "analysis_concurrency": 4,
    "enrichment_concurrency": 2
  },
  "sources": {
    "hackernews": {
      "enabled": true,
      "fetch_top_stories": 30,
      "min_score": 100
    },
    "reddit": {
      "enabled": true,
      "fetch_comments": 3,
      "subreddits": [
        { "subreddit": "MachineLearning",  "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 25, "min_score": 50 },
        { "subreddit": "LocalLLaMA",       "enabled": true, "sort": "hot", "time_filter": "day", "fetch_limit": 25, "min_score": 50 },
        { "subreddit": "programming",      "enabled": true, "sort": "top", "time_filter": "day", "fetch_limit": 25, "min_score": 100 },
        { "subreddit": "SkincareAddiction","enabled": true, "sort": "top", "time_filter": "day", "fetch_limit": 25, "min_score": 100 }
      ],
      "users": []
    },
    "rss": [
      { "name": "Simon Willison",        "url": "https://simonwillison.net/atom/everything/",                       "enabled": true, "category": "ai-tools" },
      { "name": "OpenAI Blog",           "url": "https://openai.com/news/rss.xml",                                  "enabled": true, "category": "ai-labs" },
      { "name": "Anthropic News",        "url": "https://www.anthropic.com/news/rss.xml",                           "enabled": true, "category": "ai-labs" },
      { "name": "DeepMind Blog",         "url": "https://deepmind.google/blog/rss.xml",                             "enabled": true, "category": "ai-labs" },
      { "name": "Hugging Face Blog",     "url": "https://huggingface.co/blog/feed.xml",                             "enabled": true, "category": "ai-tools" },
      { "name": "MIT Tech Review",       "url": "https://www.technologyreview.com/feed/",                           "enabled": true, "category": "tech-press" },
      { "name": "Stratechery",           "url": "https://stratechery.com/feed/",                                    "enabled": true, "category": "analysis" },
      { "name": "Pragmatic Engineer",    "url": "https://blog.pragmaticengineer.com/rss/",                          "enabled": true, "category": "engineering" },
      { "name": "Latent Space",          "url": "https://www.latent.space/feed",                                    "enabled": true, "category": "ai-podcasts" },
      { "name": "Matt Levine",           "url": "https://www.bloomberg.com/feeds/columns/matt_levine.xml",          "enabled": true, "category": "finance" },
      { "name": "Marginal Revolution",   "url": "https://feeds.feedburner.com/marginalrevolution/feed",             "enabled": true, "category": "economics" },
      { "name": "Lab Muffin",            "url": "https://labmuffin.com/feed/",                                      "enabled": true, "category": "skincare" },
      { "name": "Beautiful With Brains", "url": "https://www.beautifulwithbrains.com/feed/",                        "enabled": true, "category": "skincare" },
      { "name": "Kind of Stephen",       "url": "https://kindofstephen.com/feed/",                                  "enabled": true, "category": "skincare" },
      { "name": "JAMA Dermatology",      "url": "https://jamanetwork.com/rss/site_166/76.xml",                      "enabled": true, "category": "skincare" },
      { "name": "阮一峰周刊",             "url": "https://www.ruanyifeng.com/blog/atom.xml",                          "enabled": true, "category": "zh-tech" },
      { "name": "少数派",                 "url": "https://sspai.com/feed",                                            "enabled": true, "category": "zh-tech" },
      { "name": "Solidot",               "url": "https://www.solidot.org/index.rss",                                "enabled": true, "category": "zh-tech" }
    ],
    "github": [
      { "type": "repo_releases", "owner": "anthropics", "repo": "claude-code",   "enabled": true },
      { "type": "repo_releases", "owner": "openai",     "repo": "openai-python", "enabled": true },
      { "type": "repo_releases", "owner": "vercel",     "repo": "ai",            "enabled": true },
      { "type": "repo_releases", "owner": "BerriAI",    "repo": "litellm",       "enabled": true }
    ]
  },
  "filtering": {
    "ai_score_threshold": 6.5,
    "time_window_hours": 24
  },
  "webhook": {
    "enabled": true,
    "url_env": "TELEGRAM_WEBHOOK_URL_HORIZON",
    "delivery": "summary",
    "overview_position": "first",
    "platform": "generic",
    "layout": "markdown",
    "fallback_layout": "markdown",
    "languages": ["zh"],
    "request_body": {
      "chat_id": "",
      "text": "#{summary?limit=3800&split=\n\n}",
      "parse_mode": "Markdown",
      "disable_web_page_preview": true
    },
    "headers": ""
  }
}
